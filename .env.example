# UnifiedAIToolbox Environment Configuration
#
# Copy this file to .env and update with your actual values.
# Never commit your .env file with real credentials to version control.

# ============================================================================
# OpenAI Configuration
# ============================================================================
# Get your API key from https://platform.openai.com/api-keys
# Required for: Invoke-Model, OpenAI_Refiner.ps1, and prompt-api AI features
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default model for AI completions
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# Note: gpt-4o-mini offers best cost/performance for most workloads
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# Port Configuration
# ============================================================================
# Ports for various services - change if these ports are already in use
API_PORT=8000                # FastAPI prompt service
FRONTEND_PORT=5173          # React/Vite dashboard  
WEB_PORT=3000               # Next.js web portal
WORKBENCH_PORT=8501         # Streamlit prompt workbench

# ============================================================================
# API Security Configuration
# ============================================================================
# Optional admin token for protected endpoints (prompt sync, agent sync)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable admin token authentication
PROMPT_API_ADMIN_TOKEN=

# ============================================================================
# Orchestration Bridge Configuration (Optional)
# ============================================================================
# URL for the prompt API service used by orchestration-bridge
# PROMPT_API_URL=http://localhost:8000

# Polling interval for bridge service (seconds)
# BRIDGE_POLL_SECONDS=60

# Hours between automated reviews for critical prompts
# BRIDGE_REVIEW_INTERVAL_HOURS=24
