# UnifiedAIToolbox Environment Configuration
#
# Copy this file to .env and update with your actual values.

# ============================================================================
# OpenAI Configuration (REQUIRED)
# ============================================================================
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Engine UI (client-side orchestration) key. For local use only.
# If omitted, Start-Toolbox.ps1 will mirror OPENAI_API_KEY into this value at runtime.
# NEXT_PUBLIC_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Default model is GPT-5.2 for advanced AI orchestration
OPENAI_MODEL=gpt-5.2

# ============================================================================
# Service Ports (Optional - defaults shown)
# ============================================================================
API_PORT=8000                # FastAPI backend
WEB_PORT=3000               # Next.js web portal
PROMPT_API_HOST=127.0.0.1   # Bind API to localhost by default

# ============================================================================
# Security Controls (Recommended)
# ============================================================================
# Explicitly set tokens for orchestration/admin mutation endpoints.
# Use a long random value for each.
# PROMPT_API_ADMIN_TOKEN=change-me-admin-token
# PROMPT_API_EXECUTION_TOKEN=change-me-execution-token
# AUTH_ADMIN_USERNAME=admin
# AUTH_ADMIN_PASSWORD=change-me-strong-password
#
# Local-only bypass for development convenience.
# Default runtime behavior allows bypass only in dev/test when this is unset.
# Set to false for shared environments.
# ALLOW_INSECURE_LOCAL=false

# ============================================================================
# Artifact Normalization (Optional - defaults shown)
# ============================================================================
# Enable automatic normalization of generated artifacts
NORMALIZE_ARTIFACTS=true
# Strict mode: fail if critical issues remain after normalization
NORMALIZE_STRICT=false

# ============================================================================
# Feature Flags (Scaffold)
# ============================================================================
# Do not enable unless explicitly instructed; these flags are scaffolding for future pipeline work.
HARDENING_PIPELINE=false
PARALLEL_TEAMS=false
MAX_PARALLEL_TEAMS=4
REQUIREMENT_WIZARD=false

# MCP runtime governance enforcement for orchestration tool calls
MCP_ENFORCEMENT_ENABLED=true

# ============================================================================
# GitHub Integration (Optional)
# ============================================================================
# Get your token from: https://github.com/settings/tokens
# Required scopes: repo (full access)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Swarms Engine (Optional)
# ============================================================================
# If set, the web UI + orchestration will use this python interpreter to run Swarms.
# Recommended: run `pwsh ./scripts/Setup-Swarms.ps1` and set to the printed path.
# SWARMS_PYTHON_BIN=.uaitoolbox\\swarms\\.venv\\Scripts\\python.exe
# Optional: default swarm type used by toolbox runner (e.g., SequentialWorkflow, ConcurrentWorkflow, auto)
# SWARM_TYPE=SequentialWorkflow
