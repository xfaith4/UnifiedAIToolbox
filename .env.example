# UnifiedAIToolbox Environment Configuration
#
# Copy this file to .env and update with your actual values.

# ============================================================================
# OpenAI Configuration (REQUIRED)
# ============================================================================
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Default model is GPT-5.2 for advanced AI orchestration
OPENAI_MODEL=gpt-5.2

# ============================================================================
# Service Ports (Optional - defaults shown)
# ============================================================================
API_PORT=8000                # FastAPI backend
WEB_PORT=3000               # Next.js web portal

# ============================================================================
# GitHub Integration (Optional)
# ============================================================================
# Get your token from: https://github.com/settings/tokens
# Required scopes: repo (full access)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Swarms Engine (Optional)
# ============================================================================
# If set, the web UI + orchestration will use this python interpreter to run Swarms.
# Recommended: run `pwsh ./scripts/Setup-Swarms.ps1` and set to the printed path.
# SWARMS_PYTHON_BIN=.uaitoolbox\\swarms\\.venv\\Scripts\\python.exe
# Optional: default swarm type used by toolbox runner (e.g., SequentialWorkflow, ConcurrentWorkflow, auto)
# SWARM_TYPE=SequentialWorkflow
