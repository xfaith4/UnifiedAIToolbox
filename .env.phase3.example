# Phase 3 Environment Configuration
# Unified AI Toolbox v2.0
# Copy this file to .env.phase3 and update values

# ==============================================================================
# Database Configuration (PostgreSQL)
# ==============================================================================

# Database type: postgresql (Phase 3) or sqlite (legacy)
DATABASE_TYPE=postgresql

# PostgreSQL connection string
# Format: postgresql://username:password@hostname:port/database
DATABASE_URL=postgresql://unified_user:CHANGE_ME@localhost:5432/unified_dev

# Connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Legacy SQLite (for migration and testing)
SQLITE_PATH=./data/sqlite/prompts.db
SQLITE_AUTH_PATH=./data/sqlite/auth.db
SQLITE_AUDIT_PATH=./data/sqlite/audit.db

# ==============================================================================
# Redis Cache Configuration
# ==============================================================================

REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Cache TTL settings (in seconds)
CACHE_DEFAULT_TTL=3600
CACHE_PROMPTS_TTL=1800
CACHE_USERS_TTL=900
CACHE_TENANT_TTL=7200

# ==============================================================================
# Multi-Tenancy Configuration
# ==============================================================================

# Enable multi-tenancy features
MULTI_TENANCY_ENABLED=true

# Default tenant for single-tenant mode or testing
DEFAULT_TENANT_SLUG=default

# Tenant identification methods
TENANT_SUBDOMAIN_ENABLED=true      # Extract from subdomain (tenant.app.com)
TENANT_URL_PATH_ENABLED=true       # Extract from URL path (/t/tenant/...)

# Tenant provisioning
AUTO_PROVISION_TENANTS=false       # Auto-create tenants on first access
REQUIRE_TENANT_APPROVAL=true       # New tenants need admin approval

# ==============================================================================
# Authentication & Authorization
# ==============================================================================

# JWT Configuration
JWT_SECRET_KEY=CHANGE_ME_USE_STRONG_RANDOM_STRING_32_CHARS_MIN
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Requirements
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ==============================================================================
# AI Provider Configuration
# ==============================================================================

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=30

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-3-haiku-20240307
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_TIMEOUT=30

# Azure OpenAI (Phase 3)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=

# GitHub Integration
GITHUB_TOKEN=ghp_...
GITHUB_API_URL=https://api.github.com
GITHUB_TIMEOUT=30

# ==============================================================================
# Resource Quotas (Per-Tenant Defaults)
# ==============================================================================

# Free Plan
QUOTA_FREE_MAX_USERS=5
QUOTA_FREE_MAX_PROMPTS=100
QUOTA_FREE_MAX_API_CALLS_MONTH=10000
QUOTA_FREE_MAX_STORAGE_GB=1.0
QUOTA_FREE_MAX_CONCURRENT_REQUESTS=5

# Starter Plan
QUOTA_STARTER_MAX_USERS=10
QUOTA_STARTER_MAX_PROMPTS=500
QUOTA_STARTER_MAX_API_CALLS_MONTH=50000
QUOTA_STARTER_MAX_STORAGE_GB=10.0
QUOTA_STARTER_MAX_CONCURRENT_REQUESTS=20

# Professional Plan
QUOTA_PROFESSIONAL_MAX_USERS=50
QUOTA_PROFESSIONAL_MAX_PROMPTS=5000
QUOTA_PROFESSIONAL_MAX_API_CALLS_MONTH=500000
QUOTA_PROFESSIONAL_MAX_STORAGE_GB=100.0
QUOTA_PROFESSIONAL_MAX_CONCURRENT_REQUESTS=100

# Enterprise Plan (null = unlimited)
QUOTA_ENTERPRISE_MAX_USERS=
QUOTA_ENTERPRISE_MAX_PROMPTS=
QUOTA_ENTERPRISE_MAX_API_CALLS_MONTH=
QUOTA_ENTERPRISE_MAX_STORAGE_GB=
QUOTA_ENTERPRISE_MAX_CONCURRENT_REQUESTS=500

# ==============================================================================
# Storage Configuration
# ==============================================================================

# Storage backend: local, s3, gcs, azure
STORAGE_TYPE=local

# Local storage (development)
STORAGE_PATH=./data/storage
STORAGE_MAX_SIZE_MB=1000

# S3 Configuration (production)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=

# GCS Configuration (alternative)
GCS_BUCKET=
GCS_PROJECT_ID=
GCS_CREDENTIALS_FILE=

# Azure Blob Storage (alternative)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=

# ==============================================================================
# Feature Flags
# ==============================================================================

FEATURE_MULTI_TENANCY=true
FEATURE_KUBERNETES_DEPLOYMENT=false
FEATURE_SEMANTIC_SEARCH=false
FEATURE_ADVANCED_ANALYTICS=false
FEATURE_REAL_TIME_COLLABORATION=false
FEATURE_MARKETPLACE=false
FEATURE_MOBILE_APP=false
FEATURE_SLACK_INTEGRATION=false
FEATURE_TEAMS_INTEGRATION=false
FEATURE_JIRA_INTEGRATION=false
FEATURE_VSCODE_EXTENSION=false

# ==============================================================================
# Monitoring & Observability
# ==============================================================================

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics

# Grafana
GRAFANA_ENABLED=false
GRAFANA_URL=http://localhost:3001
GRAFANA_API_KEY=

# Sentry (Error Tracking)
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging
LOG_LEVEL=INFO                     # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json                    # json or text
LOG_FILE=logs/unified-toolbox.log
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=5

# ==============================================================================
# API Configuration
# ==============================================================================

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false
API_TIMEOUT=60

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=*

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=120

# Request Limits
MAX_REQUEST_SIZE_MB=10
MAX_UPLOAD_SIZE_MB=50

# ==============================================================================
# Dashboard Configuration
# ==============================================================================

DASHBOARD_URL=http://localhost:5173
DASHBOARD_TITLE=Unified AI Toolbox
DASHBOARD_DESCRIPTION=Enterprise AI Orchestration Platform

# ==============================================================================
# Kubernetes Configuration (Phase 3)
# ==============================================================================

# Kubernetes cluster
K8S_NAMESPACE=unified-dev
K8S_CONTEXT=kind-unified-dev
K8S_CONFIG_PATH=~/.kube/config

# Helm
HELM_RELEASE_NAME=unified-toolbox
HELM_CHART_PATH=./charts/unified-toolbox

# Auto-scaling
AUTOSCALE_ENABLED=false
AUTOSCALE_MIN_REPLICAS=2
AUTOSCALE_MAX_REPLICAS=10
AUTOSCALE_TARGET_CPU=80
AUTOSCALE_TARGET_MEMORY=80

# ==============================================================================
# Billing Configuration (Phase 3+)
# ==============================================================================

# Stripe
STRIPE_ENABLED=false
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pricing
PRICING_CURRENCY=USD
PRICING_FREE_PLAN=0
PRICING_STARTER_PLAN=29
PRICING_PROFESSIONAL_PLAN=99
PRICING_ENTERPRISE_PLAN=custom

# ==============================================================================
# Email Configuration
# ==============================================================================

EMAIL_ENABLED=false
EMAIL_FROM=noreply@unified-ai.com
EMAIL_FROM_NAME=Unified AI Toolbox

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# SendGrid (alternative)
SENDGRID_API_KEY=
SENDGRID_FROM=

# ==============================================================================
# Development & Testing
# ==============================================================================

# Environment
ENVIRONMENT=development            # development, staging, production
DEBUG=true

# Testing
TESTING=false
TEST_DATABASE_URL=postgresql://test_user:test_pass@localhost:5432/test_db

# Profiling
PROFILING_ENABLED=false
PROFILING_SAMPLE_RATE=0.01

# ==============================================================================
# Security
# ==============================================================================

# Encryption
ENCRYPTION_KEY=CHANGE_ME_USE_FERNET_KEY
ENCRYPTION_ALGORITHM=fernet

# HTTPS
FORCE_HTTPS=false
HSTS_MAX_AGE=31536000

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_ONLY=true

# ==============================================================================
# Background Jobs (Phase 3+)
# ==============================================================================

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# ==============================================================================
# Advanced Features (Phase 3+)
# ==============================================================================

# Vector Database (for semantic search)
VECTOR_DB_TYPE=pgvector             # pgvector, pinecone, weaviate
VECTOR_DB_URL=
VECTOR_DB_API_KEY=

# Real-time Collaboration
COLLABORATION_ENABLED=false
WEBSOCKET_URL=ws://localhost:8000/ws

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_PROVIDER=segment          # segment, mixpanel, amplitude
ANALYTICS_API_KEY=

# ==============================================================================
# Maintenance
# ==============================================================================

MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is under maintenance. Please try again later.
MAINTENANCE_ALLOWED_IPS=127.0.0.1,::1
