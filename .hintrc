{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/forms": "off",
    "no-inline-styles": "off",
    "compat-api/html": "off",
    "typescript-config/consistent-casing": "off",
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off"
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not ios_saf <= 26",
    "not safari <= 26"
  ]
}