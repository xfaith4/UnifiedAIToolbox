{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unified-prompt-app/schemas/prompt.schema.json",
  "title": "Unified Prompt Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "blocks",
    "variables"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
      "description": "Dot-delimited identifier (analytics.divisions.performance.summary)."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version that increments on breaking text/schema changes."
    },
    "locale": {
      "type": "string",
      "pattern": "^[a-z]{2}-[A-Z]{2}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "draft",
        "deprecated"
      ]
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "email"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "ideal",
            "react-ui",
            "workbench",
            "imported"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "risk_tier": {
      "type": "string",
      "enum": [
        "low",
        "med",
        "medium",
        "high",
        "critical"
      ]
    },
    "models": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recommended": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "compatible": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "temperature": {
          "type": "number"
        },
        "top_p": {
          "type": "number"
        },
        "max_tokens": {
          "type": "integer"
        }
      }
    },
    "variables": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_]*$": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type"
          ],
          "properties": {
            "label": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "string",
                "number",
                "boolean",
                "enum",
                "list",
                "json",
                "array"
              ]
            },
            "required": {
              "type": "boolean"
            },
            "default": {},
            "validators": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "regex": {
                    "type": "string"
                  },
                  "enum": {
                    "type": "array"
                  },
                  "min": {
                    "type": "number"
                  },
                  "max": {
                    "type": "number"
                  }
                }
              }
            }
          }
        }
      }
    },
    "blocks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "instructions"
      ],
      "properties": {
        "system": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "instructions": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "constraints": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "style": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "input": {
                "type": "object"
              },
              "output": {
                "type": "string"
              }
            },
            "required": [
              "output"
            ]
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "text",
            "markdown",
            "json"
          ]
        },
        "schema": {
          "type": "string"
        }
      }
    },
    "telemetry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pii": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high",
            "may_contain"
          ]
        },
        "audit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "last_validated": {
              "type": "string",
              "format": "date-time"
            },
            "runs": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "timestamp": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "status": {
                    "type": "string"
                  },
                  "reviewers": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "notes": {
                    "type": "string"
                  },
                  "manifest": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                },
                "required": [
                  "timestamp",
                  "status"
                ]
              }
            },
            "tests": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "mode": {
                    "type": "string"
                  },
                  "asserts": {
                    "type": "object"
                  }
                },
                "required": [
                  "mode"
                ]
              }
            }
          }
        }
      }
    },
    "integrations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ui": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title": {
              "type": "string"
            },
            "category": {
              "type": "string"
            },
            "context": {
              "type": "string"
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "workbench": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "endpoint": {
              "type": "string"
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "orchestration": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "review_policy": {
              "type": "string",
              "enum": [
                "none",
                "standard",
                "critical"
              ]
            }
          }
        }
      }
    }
  }
}