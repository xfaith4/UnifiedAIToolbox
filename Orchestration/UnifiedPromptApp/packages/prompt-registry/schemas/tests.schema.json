{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PromptTests",
  "type": "object",
  "required": [
    "cases"
  ],
  "properties": {
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "input",
          "asserts"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "input": {
            "type": "object"
          },
          "asserts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "contains": {
                  "type": "string"
                },
                "not_contains": {
                  "type": "string"
                },
                "contains_regex": {
                  "type": "string"
                },
                "max_words": {
                  "type": "number"
                },
                "is_json": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    }
  }
}