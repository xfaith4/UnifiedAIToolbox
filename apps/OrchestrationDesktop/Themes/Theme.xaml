<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- Accent + Base Palette (Dark) -->
  <Color x:Key="AccentColor">#3BA0FF</Color>
  <Color x:Key="Bg0">#0B0F1A</Color>
  <Color x:Key="Bg1">#0F1524</Color>
  <Color x:Key="CardBg">#121A2C</Color>
  <Color x:Key="Border1">#21304A</Color>
  <Color x:Key="TextPrimary">#E8EEF6</Color>
  <Color x:Key="TextSecondary">#A9B6CC</Color>
  <Color x:Key="Danger">#FF5A5F</Color>
  <Color x:Key="Warn">#FFB54C</Color>
  <Color x:Key="Success">#39D98A</Color>

  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource Bg0}"/>
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Bg1}"/>
  <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardBg}"/>
  <SolidColorBrush x:Key="BorderBrush1" Color="{StaticResource Border1}"/>
  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextPrimary}"/>
  <SolidColorBrush x:Key="SubTextBrush" Color="{StaticResource TextSecondary}"/>
  <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
  <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource Warn}"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>

  <!-- Typography -->
  <FontFamily x:Key="UIFont">Segoe UI Variable</FontFamily>
  <FontFamily x:Key="CodeFont">Cascadia Code</FontFamily>
  <sys:Double x:Key="FontBase">13</sys:Double>
  <sys:Double x:Key="FontSm">12</sys:Double>
  <sys:Double x:Key="FontLg">16</sys:Double>
  <sys:Double x:Key="Radius">12</sys:Double>

  <!-- Card -->
  <Style x:Key="Card" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource CardBrush}"/>
    <Setter Property="CornerRadius" Value="{StaticResource Radius}"/>
    <Setter Property="Padding" Value="16"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <!-- Buttons -->
  <Style TargetType="Button" x:Key="PrimaryButton">
    <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
    <Setter Property="Padding" Value="10,8"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border CornerRadius="{StaticResource Radius}" Background="{TemplateBinding Background}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,6"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Opacity" Value="0.45"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="#4CB0FF"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter Property="Background" Value="#2696F5"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="Button" x:Key="GhostButton" BasedOn="{StaticResource {x:Type Button}}">
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
    <Setter Property="Padding" Value="10,8"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border CornerRadius="{StaticResource Radius}" Background="{TemplateBinding Background}" BorderBrush="{StaticResource BorderBrush1}" BorderThickness="1">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,6"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="#172038"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- TextBoxes -->
  <Style TargetType="TextBox">
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush1}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8"/>
    <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TextBox">
          <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
            <ScrollViewer x:Name="PART_ContentHost"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Badges -->
  <Style x:Key="Badge" TargetType="Border" BasedOn="{StaticResource Card}">
    <Setter Property="Padding" Value="6,2"/>
    <Setter Property="CornerRadius" Value="999"/>
    <Setter Property="Background" Value="#1C2947"/>
    <Setter Property="BorderBrush" Value="#2B3A5E"/>
  </Style>

</ResourceDictionary>
