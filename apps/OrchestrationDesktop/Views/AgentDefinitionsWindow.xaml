<Window x:Class="OrchestrationDesktop.Views.AgentDefinitionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent Definitions"
        Height="520"
        Width="920"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Column="0" BorderBrush="#d9e0ee" BorderThickness="1" CornerRadius="8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                    <Button x:Name="AddAgentButton"
                            Content="Add"
                            Width="60"
                            Margin="0,0,6,0"
                            Click="OnAddAgent"/>
                    <Button x:Name="RemoveAgentButton"
                            Content="Remove"
                            Width="70"
                            Click="OnRemoveAgent"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding Agents}"
                         SelectedItem="{Binding SelectedAgent}"
                         DisplayMemberPath="DisplayName"
                         Margin="8"
                         HorizontalContentAlignment="Stretch"/>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" BorderBrush="#d9e0ee" BorderThickness="1" CornerRadius="8" Padding="16">
            <StackPanel x:Name="DetailsPanel">
                <TextBlock Text="Agent Name" FontWeight="SemiBold"/>
                <TextBox Text="{Binding SelectedAgent.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

                <TextBlock Text="Role" FontWeight="SemiBold"/>
                <TextBox Text="{Binding SelectedAgent.Role, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12"/>

                <TextBlock Text="Persona Prompt" FontWeight="SemiBold"/>
                <TextBox Text="{Binding SelectedAgent.Prompt, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="220"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save"
                    Width="90"
                    Margin="0,12,8,0"
                    Click="OnSave"/>
            <Button Content="Close"
                    Width="90"
                    Margin="0,12,0,0"
                    Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
