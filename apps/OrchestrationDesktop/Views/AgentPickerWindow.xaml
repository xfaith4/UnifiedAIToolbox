<Window x:Class="OrchestrationDesktop.Views.AgentPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Agent"
        Width="420"
        Height="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnConfirm"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>

        <StackPanel>
            <TextBox x:Name="SearchBox" Margin="0,0,0,12" TextChanged="OnFilterChanged"/>
            <ListBox x:Name="AgentList"
                     DisplayMemberPath="Name"
                     MinHeight="220"
                     MouseDoubleClick="OnAgentDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Role}" Foreground="#4b5b78" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </DockPanel>
</Window>
