<Window x:Class="OrchestrationDesktop.Views.ApiKeyPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenAI API Key Required"
        Width="440"
        MinHeight="260"
        MinWidth="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Enter your OpenAI API key to unlock orchestration features."
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   FontSize="14"/>

        <TextBlock x:Name="ExistingKeyText"
                   Grid.Row="1"
                   Text="An API key is already present in the environment. You can keep using it or replace it for this session."
                   TextWrapping="Wrap"
                   Foreground="#445"
                   Margin="0,0,0,12"
                   Visibility="Collapsed"/>

        <StackPanel Grid.Row="2"
                    Orientation="Vertical">
            <TextBlock Text="OpenAI API key"
                       Margin="0,0,0,4"/>
            <PasswordBox x:Name="ApiKeyBox"
                         PasswordChar="●"
                         MinWidth="240"
                         PasswordChanged="OnPasswordChanged"
                         KeyDown="OnPasswordBoxKeyDown"/>
        </StackPanel>

        <TextBlock x:Name="ErrorText"
                   Grid.Row="3"
                   Foreground="#b91c1c"
                   Margin="0,8,0,0"
                   Visibility="Collapsed"
                   Text="Enter a valid API key to continue."/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,16,0,0">
            <Button x:Name="UseExistingButton"
                    Content="Use Stored Key"
                    Width="120"
                    Margin="0,0,16,0"
                    Visibility="Collapsed"
                    Click="OnUseExisting"/>
            <Button Content="Cancel"
                    Width="80"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="OnCancel"/>
            <Button Content="OK"
                    Width="100"
                    IsDefault="True"
                    Click="OnOk"/>
        </StackPanel>
    </Grid>
</Window>
