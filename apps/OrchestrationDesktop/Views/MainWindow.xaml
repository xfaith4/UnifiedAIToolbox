<Window x:Class="OrchestrationDesktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xcad="http://schemas.xceed.com/wpf/xaml/avalondock"
        Title="AI Orchestration Desktop"
        Height="720"
        Width="1080"
        WindowStartupLocation="CenterScreen">
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Tools">
                <MenuItem Header="Milestone _Dashboard" Command="{Binding OpenDashboardCommand}"/>
                <Separator/>
                <MenuItem Header="Agent _Definitions..." Click="OnOpenAgentDefinitions"/>
                <MenuItem Header="Refine All Prompts (Batch)..." Click="OnOpenPromptBatchRefinement"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="View _Documentation" Click="OnOpenHelp"/>
                <MenuItem Header="_About" Click="OnShowAbout"/>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top" Background="#1b2a4b" Padding="20" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="56" Height="56" CornerRadius="10" Background="#314878" Margin="0,0,16,0">
                        <TextBlock Text="AI" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="AI Orchestration Desktop" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="Coordinate milestone planning, validation, and Codex swarms" Foreground="#dfe6ff"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Validate" Width="110" Margin="0,0,8,0" Command="{Binding ValidateCommand}"/>
                    <Button Content="Run Codex Only" Width="130" Margin="0,0,8,0" Command="{Binding RunCodexCommand}"/>
                    <Button Content="Run Unified Flow" Width="140" Margin="0,0,8,0" Command="{Binding RunUnifiedCommand}"/>
                    <Button Content="Cancel" Width="90" Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" MinWidth="300"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,0,16">
                    <GroupBox Header="Repository" Margin="0,0,0,12">
                        <StackPanel Margin="8">
                            <TextBlock Text="Root Path"/>
                            <DockPanel Margin="0,4,0,8">
                                <TextBox Text="{Binding RepoRoot}" MinWidth="220"/>
                                <Button Content="Browse" Margin="8,0,0,0" Padding="6,2" Command="{Binding BrowseRepoCommand}"/>
                            </DockPanel>
                            
                            <TextBlock Text="Or enter goal directly:" Margin="0,8,0,4"/>
                            <TextBox Text="{Binding DirectGoalText, UpdateSourceTrigger=PropertyChanged}" 
                                   MinHeight="80" 
                                   TextWrapping="Wrap" 
                                   AcceptsReturn="True"
                                   VerticalScrollBarVisibility="Auto"/>
                            
                            <TextBlock Text="Or select goal file:" Margin="0,8,0,4"/>
                            <DockPanel Margin="0,4,0,0">
                                <TextBox Text="{Binding GoalFile}" MinWidth="220" IsEnabled="{Binding IsGoalFileInputEnabled}"/>
                                <Button Content="Pick" Margin="8,0,0,0" Padding="6,2" Command="{Binding BrowseGoalCommand}" IsEnabled="{Binding IsGoalFileInputEnabled}"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Prompt &amp; Agent" Margin="0,0,0,12">
                        <StackPanel Margin="8">
                            <TextBlock Text="Prompt (library id)"/>
                            <DockPanel Margin="0,4,0,8">
                                <TextBox Text="{Binding SelectedPromptId}" MinWidth="220"/>
                                <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                                    <Button Content="Choose" Width="70" Margin="0,0,6,0" Click="OnSelectPromptTemplate"/>
                                    <Button Content="Clear" Width="60" Click="OnClearPromptTemplate"/>
                                </StackPanel>
                            </DockPanel>
                            <TextBlock Text="Custom Prompt (optional)"/>
                            <TextBox Text="{Binding CustomPromptText}" Margin="0,4,0,12" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>
                            <TextBlock Text="Agent Id"/>
                            <DockPanel Margin="0,4,0,4">
                                <TextBox Text="{Binding SelectedAgentId}" MinWidth="220" IsEnabled="{Binding CanEditAgentId}"/>
                                <StackPanel Orientation="Horizontal" Margin="8,0,0,0">
                                    <Button Content="Choose" Width="70" Margin="0,0,6,0" Click="OnSelectAgent" IsEnabled="{Binding CanEditAgentId}"/>
                                    <Button Content="Clear" Width="60" Click="OnClearAgent" IsEnabled="{Binding CanEditAgentId}"/>
                                </StackPanel>
                            </DockPanel>
                            <CheckBox Content="Auto-select agent based on prompt tags" IsChecked="{Binding AutoSelectAgent}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Milestone Orchestration" Margin="0,0,0,12">
                        <StackPanel Margin="8">
                            <TextBlock Text="Model"/>
                            <TextBox Text="{Binding Model}" Margin="0,4,0,8"/>
                            <TextBlock Text="Instruction"/>
                            <Grid Margin="0,4,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding ModelInstruction}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"/>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <Button Content="Library" Width="100" Margin="0,0,0,6" Click="OnSelectMilestoneInstruction"/>
                                    <Button Content="Clear" Width="100" Click="OnClearMilestoneInstruction"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Width="150">
                                    <TextBlock Text="Max Iterations"/>
                                    <TextBox Text="{Binding MaxIterations}" Margin="0,4,12,0"/>
                                </StackPanel>
                                <StackPanel Width="150">
                                    <TextBlock Text="Pass Threshold"/>
                                    <TextBox Text="{Binding PassThreshold}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Codex Swarm">
                        <StackPanel Margin="8">
                            <TextBlock Text="Model"/>
                            <TextBox Text="{Binding CodexModel}" Margin="0,4,0,8"/>
                            <TextBlock Text="Instruction"/>
                            <Grid Margin="0,4,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding CodexInstruction}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"/>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <Button Content="Library" Width="100" Margin="0,0,0,6" Click="OnSelectCodexInstruction"/>
                                    <Button Content="Clear" Width="100" Click="OnClearCodexInstruction"/>
                                </StackPanel>
                            </Grid>
                            <CheckBox Content="Run Codex CLI via WSL" IsChecked="{Binding UseWslForCodex}"/>
                            <TextBlock Text="Max Parallel Jobs" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding MaxParallel}" Margin="0,4,0,8"/>
                            <TextBlock Text="Work Directory"/>
                            <TextBox Text="{Binding WorkDir}" Margin="0,4,0,8"/>
                            <CheckBox Content="Skip Context Resolution" IsChecked="{Binding SkipContextResolution}" Margin="0,4,0,0"/>
                            <CheckBox Content="Skip Codex Swarm" IsChecked="{Binding SkipCodex}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          Background="#d0d7e2"
                          ShowsPreview="True"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,0,0">
                        <Button Content="Open Dashboard"
                                Margin="0,0,8,0"
                                Command="{Binding OpenDashboardCommand}"/>
                        <Button Content="View Results"
                                Command="{Binding OpenResultsCommand}"
                                IsEnabled="{Binding HasResultShortcut}"/>
                    </StackPanel>
                </Grid>

                <ProgressBar Grid.Row="1"
                             Margin="0,12,0,12"
                             Height="18"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressValue, Mode=OneWay}"
                             IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"/>

                <Border Grid.Row="2" BorderBrush="#d0d7e2" BorderThickness="1" CornerRadius="4">
                    <DockPanel Margin="8">
                        <TextBlock DockPanel.Dock="Top" Text="Output Log" FontWeight="Bold" Margin="0,0,0,8"/>
                        <FlowDocumentScrollViewer Margin="0"
                                                  Padding="0"
                                                  Document="{Binding LogDocument}"
                                                  VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
