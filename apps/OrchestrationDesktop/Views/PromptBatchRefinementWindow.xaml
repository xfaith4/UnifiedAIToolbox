<Window x:Class="OrchestrationDesktop.Views.PromptBatchRefinementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Prompt Refinement"
        Height="640"
        Width="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#d9e0ee" BorderThickness="1" CornerRadius="8" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
                    <TextBlock Text="Prompt Root"/>
                    <DockPanel Margin="0,6,0,0">
                        <TextBox Text="{Binding PromptRoot}" MinWidth="420"/>
                        <Button Content="Browse" Margin="8,0,0,0" Padding="6,2" Command="{Binding BrowsePromptRootCommand}"/>
                    </DockPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,0,0" Orientation="Horizontal">
                    <StackPanel Width="160">
                        <TextBlock Text="Mode"/>
                        <ComboBox ItemsSource="{Binding Modes}" SelectedItem="{Binding Mode}" Margin="0,6,12,0"/>
                    </StackPanel>
                    <StackPanel Width="120">
                        <TextBlock Text="Iterations"/>
                        <TextBox Text="{Binding Iterations}" Margin="0,6,12,0"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Bottom">
                        <CheckBox Content="Save Artifacts" IsChecked="{Binding SaveArtifacts}" Margin="0,0,0,4"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" BorderBrush="#d9e0ee" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,12,0,12">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold"/>
                <ProgressBar Height="16" Margin="0,8,0,0" IsIndeterminate="{Binding IsProgressIndeterminate}"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Out Root:" FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding OutRoot}" IsReadOnly="True" BorderThickness="0" Background="Transparent"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="Summary:" FontWeight="SemiBold" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding SummaryPath}" IsReadOnly="True" BorderThickness="0" Background="Transparent"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Results}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="160"/>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="130"/>
                <DataGridTextColumn Header="File" Binding="{Binding File}" Width="220"/>
                <DataGridTextColumn Header="Out File" Binding="{Binding OutFile}" Width="220"/>
                <DataGridTextColumn Header="Artifacts" Binding="{Binding ArtifactsPath}" Width="220"/>
                <DataGridTextColumn Header="Tokens" Binding="{Binding TokensUsed}" Width="90"/>
                <DataGridTextColumn Header="Cost" Binding="{Binding EstimatedCost}" Width="90"/>
                <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="240"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Run" Width="110" Margin="0,0,8,0" Command="{Binding RunCommand}"/>
            <Button Content="Cancel" Width="110" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>
