{
  "openapi": "3.1.0",
  "info": {
    "title": "AI Prompt Workbench",
    "version": "1.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        },
        "description": "Basic service health check with a UTC timestamp."
      }
    },
    "/prompts": {
      "get": {
        "summary": "List canonical prompts",
        "operationId": "list_prompt_payloads_prompts_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PromptListResponse"
                }
              }
            }
          }
        },
        "description": "Return canonical prompt payloads from the prompt registry, merged with any synced local overrides. These prompt resources are the primary UI-facing contract for render, review, and refinement workflows."
      }
    },
    "/prompts/{prompt_id}": {
      "get": {
        "summary": "Get canonical prompt",
        "operationId": "get_prompt_prompts__prompt_id__get",
        "parameters": [
          {
            "name": "prompt_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Prompt Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PromptPayload"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "description": "Return a single canonical prompt payload from `/prompts` by id."
      }
    },
    "/prompts/render": {
      "post": {
        "summary": "Render Prompt",
        "operationId": "render_prompt_prompts_render_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RenderRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RenderResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/refiner/run": {
      "post": {
        "summary": "Queue Refiner",
        "operationId": "queue_refiner_refiner_run_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefinerRunRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefinerRunResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "summary": "Metrics",
        "operationId": "metrics_metrics_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetricsResponse"
                }
              }
            }
          }
        },
        "description": "Return in-process counters for prompt rendering, refiner runs, review writes, and current queue depth."
      }
    },
    "/prompts:sync": {
      "post": {
        "summary": "Sync prompt payloads",
        "operationId": "sync_prompt_payloads_prompts_sync_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PromptSyncRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PromptSyncResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "description": "Persist locally edited prompt payloads to the sync cache used for offline development overrides."
      }
    },
    "/api/templates": {
      "get": {
        "summary": "List legacy templates",
        "operationId": "list_templates_api_templates_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateListResponse"
                }
              }
            }
          }
        },
        "description": "Return the ids of legacy YAML templates used by the generate runtime. Generation endpoints prefer canonical `/prompts` ids when available and fall back to these template files."
      }
    },
    "/api/audit": {
      "get": {
        "summary": "List audit records",
        "operationId": "list_audit_api_audit_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "title": "Limit",
              "minimum": 1,
              "maximum": 500
            },
            "description": "Maximum number of recent audit entries to return."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditListResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "description": "Return recent generation audit records. Each item can be matched from `GenerateResponse.audit_id`."
      }
    },
    "/api/templates/install-defaults": {
      "post": {
        "summary": "Install default templates",
        "description": "Create example legacy YAML templates under the local templates directory.",
        "operationId": "install_default_templates_api_templates_install_defaults_post",
        "parameters": [
          {
            "name": "overwrite",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Overwrite"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InstallDefaultTemplatesResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/templates/reload": {
      "post": {
        "summary": "Reload templates",
        "description": "Force a re-read of legacy template files from disk.",
        "operationId": "reload_templates_api_templates_reload_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReloadTemplatesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/templates/{template_id}": {
      "get": {
        "summary": "Get legacy template",
        "description": "Return the parsed YAML/JSON for a single legacy template resource. Use `/prompts/{prompt_id}` for canonical prompt payloads used by the editor and render flows.",
        "operationId": "get_template_api_templates__template_id__get",
        "parameters": [
          {
            "name": "template_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Legacy template id (matches the YAML `id` field used by `/api/templates`).",
              "title": "Template Id"
            },
            "description": "Legacy template id (matches the YAML `id` field used by `/api/templates`)."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemplateDocument"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/generate/dry-run": {
      "post": {
        "summary": "Generate dry run",
        "description": "Build the final chat messages without calling OpenAI. This resolves `template_id` against canonical `/prompts` first, then legacy `/api/templates` if needed.",
        "operationId": "generate_dry_run_api_generate_dry_run_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DryRunResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/generate": {
      "post": {
        "summary": "Generate",
        "operationId": "generate_api_generate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "description": "Execute prompt generation against OpenAI. The supplied `template_id` first resolves against canonical `/prompts` ids and falls back to legacy `/api/templates`."
      }
    }
  },
  "components": {
    "schemas": {
      "GenerateResponse": {
        "properties": {
          "cached": {
            "type": "boolean",
            "title": "Cached"
          },
          "cache_key": {
            "type": "string",
            "title": "Cache Key"
          },
          "template_id": {
            "type": "string",
            "title": "Template Id",
            "description": "Identifier used for generation. This may be a canonical prompt id from `/prompts` or a legacy YAML template id from `/api/templates`."
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "output": {
            "additionalProperties": true,
            "type": "object",
            "title": "Output"
          },
          "audit_id": {
            "type": "integer",
            "title": "Audit Id",
            "description": "Audit record id that can be retrieved from `/api/audit`."
          }
        },
        "type": "object",
        "required": [
          "cached",
          "cache_key",
          "template_id",
          "model",
          "output",
          "audit_id"
        ],
        "title": "GenerateResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "InputData": {
        "properties": {
          "log_snippet": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Log Snippet"
          },
          "timestamp": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timestamp"
          }
        },
        "type": "object",
        "title": "InputData"
      },
      "PromptSyncRequest": {
        "properties": {
          "prompts": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Prompts"
          }
        },
        "type": "object",
        "title": "PromptSyncRequest"
      },
      "RefinerRunRequest": {
        "properties": {
          "prompt_id": {
            "type": "string",
            "title": "Prompt Id"
          },
          "invoke_refiner": {
            "type": "boolean",
            "title": "Invoke Refiner",
            "default": true
          },
          "dry_run": {
            "type": "boolean",
            "title": "Dry Run",
            "default": false
          },
          "reviewers": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Reviewers"
          },
          "notes": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          }
        },
        "type": "object",
        "required": [
          "prompt_id"
        ],
        "title": "RefinerRunRequest"
      },
      "RefinerRunResponse": {
        "properties": {
          "prompt_id": {
            "type": "string",
            "title": "Prompt Id"
          },
          "manifest": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Manifest"
          },
          "refiner_invoked": {
            "type": "boolean",
            "title": "Refiner Invoked"
          },
          "dry_run": {
            "type": "boolean",
            "title": "Dry Run"
          },
          "reviewers": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Reviewers"
          },
          "notes": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          }
        },
        "type": "object",
        "required": [
          "prompt_id",
          "manifest",
          "refiner_invoked",
          "dry_run",
          "reviewers",
          "notes"
        ],
        "title": "RefinerRunResponse"
      },
      "RenderRequest": {
        "properties": {
          "prompt_id": {
            "type": "string",
            "title": "Prompt Id",
            "description": "Canonical prompt id from `/prompts` used by render and refiner workflows."
          },
          "variables": {
            "additionalProperties": true,
            "type": "object",
            "title": "Variables"
          }
        },
        "type": "object",
        "required": [
          "prompt_id"
        ],
        "title": "RenderRequest"
      },
      "RenderResponse": {
        "properties": {
          "prompt": {
            "additionalProperties": true,
            "type": "object",
            "title": "Prompt"
          },
          "rendered_blocks": {
            "additionalProperties": true,
            "type": "object",
            "title": "Rendered Blocks"
          }
        },
        "type": "object",
        "required": [
          "prompt",
          "rendered_blocks"
        ],
        "title": "RenderResponse"
      },
      "RequestPayload": {
        "properties": {
          "template_id": {
            "type": "string",
            "title": "Template Id",
            "description": "Execution resource identifier used by `/api/generate` and `/api/generate/dry-run`. The runtime first attempts to resolve this value as a canonical prompt id from `/prompts`, then falls back to a legacy YAML template under `/api/templates/{template_id}`."
          },
          "role": {
            "type": "string",
            "title": "Role",
            "description": "e.g., Genesys Cloud Monitoring Assistant"
          },
          "task": {
            "type": "string",
            "title": "Task",
            "description": "e.g., Explain likely causes and mitigations for WebRTC disconnects"
          },
          "context": {
            "additionalProperties": true,
            "type": "object",
            "title": "Context",
            "description": "e.g., {'environment':'Prod','audience':['Executives','NOC Engineers'],'scale':'100k agents, 12 BPO partners'}"
          },
          "input_data": {
            "$ref": "#/components/schemas/InputData"
          },
          "desired_output": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Desired Output"
          },
          "modes": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Modes"
          },
          "model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model"
          }
        },
        "type": "object",
        "required": [
          "template_id",
          "role",
          "task",
          "context"
        ],
        "title": "RequestPayload"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "HealthResponse": {
        "properties": {
          "ok": {
            "type": "boolean",
            "title": "Ok"
          },
          "time": {
            "type": "string",
            "title": "Time",
            "description": "UTC timestamp when the health check was generated."
          }
        },
        "type": "object",
        "required": [
          "ok",
          "time"
        ],
        "title": "HealthResponse"
      },
      "MetricsResponse": {
        "properties": {
          "renders_total": {
            "type": "integer",
            "title": "Renders Total"
          },
          "render_errors": {
            "type": "integer",
            "title": "Render Errors"
          },
          "refiner_runs": {
            "type": "integer",
            "title": "Refiner Runs"
          },
          "refiner_errors": {
            "type": "integer",
            "title": "Refiner Errors"
          },
          "review_records": {
            "type": "integer",
            "title": "Review Records"
          },
          "refiner_queue_depth": {
            "type": "integer",
            "title": "Refiner Queue Depth"
          }
        },
        "type": "object",
        "required": [
          "renders_total",
          "render_errors",
          "refiner_runs",
          "refiner_errors",
          "review_records",
          "refiner_queue_depth"
        ],
        "title": "MetricsResponse"
      },
      "PromptVariableDefinition": {
        "properties": {
          "type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
