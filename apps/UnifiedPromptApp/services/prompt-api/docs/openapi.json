{
  "openapi": "3.1.0",
  "info": {
    "title": "AI Prompt Workbench",
    "version": "1.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/prompts": {
      "get": {
        "summary": "List Prompt Payloads",
        "operationId": "list_prompt_payloads_prompts_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/prompts/{prompt_id}": {
      "get": {
        "summary": "Get Prompt",
        "operationId": "get_prompt_prompts__prompt_id__get",
        "parameters": [
          {
            "name": "prompt_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Prompt Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/prompts/render": {
      "post": {
        "summary": "Render Prompt",
        "operationId": "render_prompt_prompts_render_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RenderRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RenderResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/refiner/run": {
      "post": {
        "summary": "Queue Refiner",
        "operationId": "queue_refiner_refiner_run_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefinerRunRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefinerRunResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "summary": "Metrics",
        "operationId": "metrics_metrics_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/prompts:sync": {
      "post": {
        "summary": "Sync Prompt Payloads",
        "operationId": "sync_prompt_payloads_prompts_sync_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PromptSyncRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/templates": {
      "get": {
        "summary": "List Templates",
        "operationId": "list_templates_api_templates_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/audit": {
      "get": {
        "summary": "List Audit",
        "operationId": "list_audit_api_audit_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/templates/install-defaults": {
      "post": {
        "summary": "Install Default Templates",
        "description": "Create a couple of example templates under ./templates.",
        "operationId": "install_default_templates_api_templates_install_defaults_post",
        "parameters": [
          {
            "name": "overwrite",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Overwrite"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/templates/reload": {
      "post": {
        "summary": "Reload Templates",
        "description": "Force re-read of template files (stateless, but useful for debugging).",
        "operationId": "reload_templates_api_templates_reload_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/templates/{template_id}": {
      "get": {
        "summary": "Get Template",
        "description": "Return the parsed YAML/JSON for a single template.",
        "operationId": "get_template_api_templates__template_id__get",
        "parameters": [
          {
            "name": "template_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Template id (matches YAML 'id')",
              "title": "Template Id"
            },
            "description": "Template id (matches YAML 'id')"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/generate/dry-run": {
      "post": {
        "summary": "Generate Dry Run",
        "description": "Build the final messages but do NOT call OpenAI.\nUseful to verify substitutions and output contract before billing tokens.",
        "operationId": "generate_dry_run_api_generate_dry_run_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/generate": {
      "post": {
        "summary": "Generate",
        "operationId": "generate_api_generate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RequestPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerateResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GenerateResponse": {
        "properties": {
          "cached": {
            "type": "boolean",
            "title": "Cached"
          },
          "cache_key": {
            "type": "string",
            "title": "Cache Key"
          },
          "template_id": {
            "type": "string",
            "title": "Template Id"
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "output": {
            "additionalProperties": true,
            "type": "object",
            "title": "Output"
          },
          "audit_id": {
            "type": "integer",
            "title": "Audit Id"
          }
        },
        "type": "object",
        "required": [
          "cached",
          "cache_key",
          "template_id",
          "model",
          "output",
          "audit_id"
        ],
        "title": "GenerateResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "InputData": {
        "properties": {
          "log_snippet": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Log Snippet"
          },
          "timestamp": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timestamp"
          }
        },
        "type": "object",
        "title": "InputData"
      },
      "PromptSyncRequest": {
        "properties": {
          "prompts": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Prompts"
          }
        },
        "type": "object",
        "title": "PromptSyncRequest"
      },
      "RefinerRunRequest": {
        "properties": {
          "prompt_id": {
            "type": "string",
            "title": "Prompt Id"
          },
          "invoke_refiner": {
            "type": "boolean",
            "title": "Invoke Refiner",
            "default": true
          },
          "dry_run": {
            "type": "boolean",
            "title": "Dry Run",
            "default": false
          },
          "reviewers": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Reviewers"
          },
          "notes": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          }
        },
        "type": "object",
        "required": [
          "prompt_id"
        ],
        "title": "RefinerRunRequest"
      },
      "RefinerRunResponse": {
        "properties": {
          "prompt_id": {
            "type": "string",
            "title": "Prompt Id"
          },
          "manifest": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Manifest"
          },
          "refiner_invoked": {
            "type": "boolean",
            "title": "Refiner Invoked"
          },
          "dry_run": {
            "type": "boolean",
            "title": "Dry Run"
          },
          "reviewers": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Reviewers"
          },
          "notes": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          }
        },
        "type": "object",
        "required": [
          "prompt_id",
          "manifest",
          "refiner_invoked",
          "dry_run",
          "reviewers",
          "notes"
        ],
        "title": "RefinerRunResponse"
      },
      "RenderRequest": {
        "properties": {
          "prompt_id": {
            "type": "string",
            "title": "Prompt Id"
          },
          "variables": {
            "additionalProperties": true,
            "type": "object",
            "title": "Variables"
          }
        },
        "type": "object",
        "required": [
          "prompt_id"
        ],
        "title": "RenderRequest"
      },
      "RenderResponse": {
        "properties": {
          "prompt": {
            "additionalProperties": true,
            "type": "object",
            "title": "Prompt"
          },
          "rendered_blocks": {
            "additionalProperties": true,
            "type": "object",
            "title": "Rendered Blocks"
          }
        },
        "type": "object",
        "required": [
          "prompt",
          "rendered_blocks"
        ],
        "title": "RenderResponse"
      },
      "RequestPayload": {
        "properties": {
          "template_id": {
            "type": "string",
            "title": "Template Id",
            "description": "e.g., agent_webrtc_disconnect_v1.0.0"
          },
          "role": {
            "type": "string",
            "title": "Role",
            "description": "e.g., Genesys Cloud Monitoring Assistant"
          },
          "task": {
            "type": "string",
            "title": "Task",
            "description": "e.g., Explain likely causes and mitigations for WebRTC disconnects"
          },
          "context": {
            "additionalProperties": true,
            "type": "object",
            "title": "Context",
            "description": "e.g., {'environment':'Prod','audience':['Executives','NOC Engineers'],'scale':'100k agents, 12 BPO partners'}"
          },
          "input_data": {
            "$ref": "#/components/schemas/InputData"
          },
          "desired_output": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Desired Output"
          },
          "modes": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Modes"
          },
          "model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model"
          }
        },
        "type": "object",
        "required": [
          "template_id",
          "role",
          "task",
          "context"
        ],
        "title": "RequestPayload"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}