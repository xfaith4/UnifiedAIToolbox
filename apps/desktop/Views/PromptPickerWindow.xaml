<Window x:Class="OrchestrationDesktop.Views.PromptPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Prompt"
        Width="560"
        Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnConfirm"/>
            <Button Content="Cancel" Width="80" IsCancel="True"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Find a prompt" FontWeight="SemiBold"/>
                <TextBox x:Name="SearchBox" Margin="0,6,0,12" TextChanged="OnFilterChanged"/>
                <ListBox x:Name="PromptList"
                         SelectionMode="Single"
                         MinHeight="320"
                         MouseDoubleClick="OnPromptDoubleClick"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Id}" FontSize="12" Foreground="#4b5b78"/>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12" Foreground="#31394d"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
