# Next.js Unified Toolbox WebApp - Local Environment Configuration
# Copy this file to .env.local and update with your values

# ============================================================================
# Backend API Configuration
# ============================================================================
# URL for the Prompt API backend service
# This enables the frontend to communicate with the backend for orchestration
# Default: http://localhost:8000 (for local development)
# Production: Update to match your deployed API endpoint
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Alternative: You can also use NEXT_PUBLIC_PROMPT_API_BASE
# The frontend will check both variables
# NEXT_PUBLIC_PROMPT_API_BASE=http://localhost:8000

# Optional OpenAI configuration for the Prompt Refiner
# Provide server-side key for API route and client-side key to enable UI toggle
OPENAI_API_KEY=
NEXT_PUBLIC_OPENAI_API_KEY=
# Optional override for the model used in the AI refiner endpoint
OPENAI_PROMPT_REFINER_MODEL=gpt-4o-mini
# Optional cost display (per 1,000 tokens)
OPENAI_REFINE_COST_PER_THOUSAND=0
