# Next.js WebApp — Local override example
#
# You do NOT need this file for normal development.
# API keys and service config come from the repo-root .env (single source of truth).
# Start-Toolbox.ps1 and next.config.ts both load it automatically.
#
# Only create .env.local if you need to OVERRIDE a specific value for your
# local machine without touching the shared repo-root .env.
#
# Example overrides:
#
# Point the webapp at a non-default API port:
# NEXT_PUBLIC_API_BASE=http://localhost:9000
#
# Use a personal API key just for this machine:
# OPENAI_API_KEY=sk-proj-your-personal-key-here
# NEXT_PUBLIC_API_KEY=sk-proj-your-personal-key-here
#
# Override the refiner model locally:
# OPENAI_PROMPT_REFINER_MODEL=gpt-4o
