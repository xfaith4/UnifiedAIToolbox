{
  "stackId": "node-next-fastify-pnpm",
  "description": "Node + pnpm workspace + Next.js web + Fastify API",
  "requiredFilesAll": [
    "package.json",
    "pnpm-workspace.yaml",
    "apps/web/package.json",
    "apps/web/tsconfig.json",
    "apps/web/next.config.*",
    "apps/web/app/page.tsx",
    "apps/api/package.json",
    "apps/api/tsconfig.json",
    "apps/api/src/server.ts"
  ],
  "requiredFilesAny": [],
  "codeFileExtensions": [
    ".ts",
    ".tsx",
    ".js",
    ".jsx",
    ".mjs",
    ".cjs",
    ".mts",
    ".cts",
    ".py",
    ".go",
    ".cs",
    ".java",
    ".rb",
    ".ps1",
    ".sh",
    ".php",
    ".rs",
    ".c",
    ".cpp",
    ".h",
    ".hpp",
    ".swift",
    ".kt"
  ],
  "forbiddenPatternsByExtension": {
    ".ts": [
      {
        "id": "md-fence",
        "description": "Markdown code fences are not allowed in code files",
        "pattern": "^\\s*```",
        "flags": "m"
      },
      {
        "id": "file-header",
        "description": "File wrappers like '## File:' are not allowed in code files",
        "pattern": "^\\s*#{1,6}\\s*File\\s*:",
        "flags": "mi"
      },
      {
        "id": "frontmatter-marker",
        "description": "YAML frontmatter markers are not allowed in code files",
        "pattern": "^(?:\\uFEFF)?\\s*---\\s*$",
        "flags": "m"
      }
    ],
    ".tsx": [
      {
        "id": "md-fence",
        "description": "Markdown code fences are not allowed in code files",
        "pattern": "^\\s*```",
        "flags": "m"
      },
