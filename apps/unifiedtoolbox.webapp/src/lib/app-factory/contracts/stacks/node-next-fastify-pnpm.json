        "pattern": "^(?:\\uFEFF)?\\s*---\\s*$",
        "flags": "m"
      }
    ]
  },
  "envVarsRequired": [],
  "installCommand": "pnpm install",
  "typecheckCommand": "pnpm -r typecheck",
  "lintCommand": "pnpm -r lint",
  "buildCommand": "pnpm -r build",
  "bootCommands": [
    {
      "name": "api-dev",
      "command": "pnpm --filter api dev",
      "env": { "PORT": "3001", "HOST": "127.0.0.1" }
    },
    {
      "name": "web-dev",
      "command": "pnpm --filter web dev",
      "env": { "PORT": "3000", "HOSTNAME": "127.0.0.1" }
    }
  ],
  "healthChecks": [
    { "name": "api-health", "url": "http://127.0.0.1:3001/health", "expectedStatus": 200, "timeoutSeconds": 120 },
    { "name": "web-root", "url": "http://127.0.0.1:3000", "expectedStatus": 200, "timeoutSeconds": 120 }
  ]
}
