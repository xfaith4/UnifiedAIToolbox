{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "contracts/common_run_contract.v1.json",
  "title": "Common Run Contract v1",
  "type": "object",
  "required": [
    "schema_version",
    "job_type",
    "contract_universe",
    "contract_version",
    "pipeline_id",
    "run_id",
    "goal",
    "agent_roster",
    "budget",
    "logging",
    "artifact_policy",
    "gate_policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "job_type": {
      "type": "string"
    },
    "contract_universe": {
      "type": "string",
      "enum": ["build_app", "maintenance"]
    },
    "contract_version": {
      "type": "string"
    },
    "pipeline_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "agent_roster": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "budget": {
      "type": "object",
      "required": ["max_time_minutes"],
      "properties": {
        "max_time_minutes": { "type": "integer" },
        "max_cost_usd": { "type": "number" },
        "max_tokens": { "type": "integer" }
      }
    },
    "logging": {
      "type": "object",
      "required": ["level"],
      "properties": {
        "level": { "type": "string" },
        "verbose": { "type": "boolean" }
      }
    },
    "artifact_policy": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string" },
        "required": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "gate_policy": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string" },
        "gates": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "stages": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object"
    }
  }
}
