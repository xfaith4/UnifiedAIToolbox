{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "contracts/maintenance_request.v1.json",
  "title": "Maintenance Request v1",
  "type": "object",
  "required": ["job_type", "goal", "repo", "intent"],
  "properties": {
    "schema_version": { "type": "string" },
    "job_type": { "type": "string", "enum": ["maintain_existing_app"] },
    "goal": { "type": "string" },
    "intent": {
      "type": "string",
      "enum": ["bugfix", "feature", "refactor", "stabilize", "docs", "dependency_update"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "repo": {
      "type": "object",
      "required": ["full_name"],
      "properties": {
        "full_name": { "type": "string" },
        "url": { "type": "string" },
        "local_path": { "type": "string" }
      }
    },
    "ref": {
      "type": "object",
      "properties": {
        "branch": { "type": "string" },
        "commit": { "type": "string" }
      }
    },
    "constraints": { "type": "object" },
    "change_surface": { "type": "object" },
    "baseline": { "type": "object" },
    "command_policy": { "type": "object" },
    "pr_policy": { "type": "object" },
    "conflict_policy": { "type": "object" },
    "repo_context": { "type": "object" },
    "budget": {
      "type": "object",
      "properties": {
        "max_time_minutes": { "type": "integer" },
        "max_cost_usd": { "type": "number" },
        "max_tokens": { "type": "integer" }
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "level": { "type": "string" },
        "verbose": { "type": "boolean" }
      }
    },
    "agent_roster": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object"
    }
  }
}
