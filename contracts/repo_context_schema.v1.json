{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "contracts/repo_context_schema.v1.json",
  "title": "Repo Context Schema v1",
  "type": "object",
  "required": [
    "schema_version",
    "repo",
    "discovery",
    "baseline"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "run_id": {
      "type": "string"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "repo": {
      "type": "object",
      "required": ["root_path"],
      "properties": {
        "root_path": { "type": "string" },
        "url": { "type": "string" },
        "branch": { "type": "string" },
        "commit": { "type": "string" },
        "ref": { "type": "string" }
      }
    },
    "discovery": {
      "type": "object",
      "required": [
        "scan",
        "detection",
        "commands",
        "ci",
        "project_layout",
        "repo_shape",
        "working_tree",
        "high_risk_areas",
        "warnings",
        "policy_hooks"
      ],
      "properties": {
        "scan": {
          "type": "object",
          "required": [
            "max_files_scanned",
            "files_scanned",
            "truncated",
            "excluded_patterns"
          ],
          "properties": {
            "max_files_scanned": { "type": "integer" },
            "files_scanned": { "type": "integer" },
            "truncated": { "type": "boolean" },
            "excluded_patterns": {
              "type": "array",
              "items": { "type": "string" }
            },
            "size_mb_estimate": { "type": "number" }
          }
        },
        "detection": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["item", "value", "confidence", "evidence_paths"],
            "properties": {
              "item": { "type": "string" },
              "value": { "type": "string" },
              "confidence": { "type": "number" },
              "evidence_paths": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "command", "confidence", "source", "evidence_paths"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["build", "test", "lint", "format"]
              },
              "command": { "type": "string" },
              "confidence": { "type": "number" },
              "source": {
                "type": "string",
                "enum": ["ci", "docs", "convention"]
              },
              "evidence_paths": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "ci": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["system", "workflows", "evidence_paths"],
            "properties": {
              "system": {
                "type": "string",
                "enum": ["github_actions", "azure_pipelines", "gitlab", "jenkins"]
              },
              "workflows": {
                "type": "array",
                "items": { "type": "string" }
              },
              "evidence_paths": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "project_layout": {
          "type": "object",
          "required": ["top_level_dirs", "root_files", "file_counts"],
          "properties": {
            "top_level_dirs": {
              "type": "array",
              "items": { "type": "string" }
            },
            "root_files": {
              "type": "array",
              "items": { "type": "string" }
            },
            "file_counts": {
              "type": "object",
              "properties": {
                "total_files": { "type": "integer" },
                "scanned_files": { "type": "integer" },
                "extension_counts": { "type": "object" }
              }
            }
          }
        },
        "repo_shape": {
          "type": "object",
          "required": ["is_monorepo", "project_roots", "size_class"],
          "properties": {
            "is_monorepo": { "type": "boolean" },
            "project_roots": {
              "type": "array",
              "items": { "type": "string" }
            },
            "size_class": {
              "type": "string",
              "enum": ["normal", "large", "unknown"]
            }
          }
        },
        "working_tree": {
          "type": "object",
          "required": ["status", "has_submodules", "has_lfs"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["clean", "dirty", "unknown"]
            },
            "has_submodules": { "type": "boolean" },
            "has_lfs": { "type": "boolean" }
          }
        },
        "high_risk_areas": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "signal", "reason"],
            "properties": {
              "path": { "type": "string" },
              "signal": { "type": "string" },
              "reason": { "type": "string" },
              "score": { "type": "number" }
            }
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["code", "severity", "message"],
            "properties": {
              "code": { "type": "string" },
              "severity": { "type": "string" },
              "message": { "type": "string" },
              "evidence_paths": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "policy_hooks": {
          "type": "object",
          "required": ["pr_status", "release", "security"],
          "properties": {
            "pr_status": {
              "type": "object",
              "required": ["status"],
              "properties": {
                "status": { "type": "string" },
                "open_pr_count": { "type": "integer" },
                "target_branches": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "release": {
              "type": "object",
              "required": ["status"],
              "properties": {
                "status": { "type": "string" },
                "tags_present": { "type": "boolean" },
                "versioning_scheme": { "type": "string" }
              }
            },
            "security": {
              "type": "object",
              "required": ["status"],
              "properties": {
                "status": { "type": "string" },
                "dependency_update_policy": { "type": "string" }
              }
            },
            "appfactory_provenance": {
              "type": "object",
              "required": ["status"],
              "properties": {
                "status": { "type": "string" },
                "known": { "type": "boolean" },
                "reason": { "type": "string" },
                "metadata_path": { "type": "string" },
                "contract_universe": { "type": "string" },
                "contract_version": { "type": "string" },
                "pipeline_id": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "baseline": {
      "type": "object",
      "required": ["attempted", "commands_run", "results", "environment", "warnings"],
      "properties": {
        "attempted": { "type": "boolean" },
        "commands_run": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "command", "confidence", "source", "evidence_paths"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["build", "test", "lint", "format"]
              },
              "command": { "type": "string" },
              "confidence": { "type": "number" },
              "source": {
                "type": "string",
                "enum": ["ci", "docs", "convention"]
              },
              "evidence_paths": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "command",
              "exit_code",
              "duration_seconds",
              "stdout_summary",
              "stderr_summary",
              "log_path"
            ],
            "properties": {
              "command": { "type": "string" },
              "exit_code": { "type": "integer" },
              "duration_seconds": { "type": "number" },
              "stdout_summary": { "type": "string" },
              "stderr_summary": { "type": "string" },
              "log_path": { "type": "string" }
            }
          }
        },
        "environment": {
          "type": "object",
          "required": [
            "os",
            "shell",
            "runtimes",
            "package_managers",
            "working_directory",
            "env_vars"
          ],
          "properties": {
            "os": { "type": "string" },
            "shell": { "type": "string" },
            "runtimes": { "type": "object" },
            "package_managers": { "type": "object" },
            "working_directory": { "type": "string" },
            "env_vars": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "present", "redacted"],
                "properties": {
                  "name": { "type": "string" },
                  "present": { "type": "boolean" },
                  "redacted": { "type": "boolean" }
                }
              }
            }
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["code", "severity", "message"],
            "properties": {
              "code": { "type": "string" },
              "severity": { "type": "string" },
              "message": { "type": "string" },
              "evidence_paths": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
