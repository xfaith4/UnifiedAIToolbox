{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "management-team/v2/ack",
  "title": "ACKV2",
  "description": "Payload for message_type=ACK. Used for explicit receipt or resolution acknowledgement without sending a substantive replacement payload.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "acknowledged_message_id",
    "acknowledged_message_type",
    "ack_status"
  ],
  "properties": {
    "acknowledged_message_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "acknowledged_message_type": {
      "$ref": "envelope.schema.json#/definitions/MessageType"
    },
    "ack_status": {
      "type": "string",
      "enum": [
        "received",
        "understood",
        "satisfied_by_reference"
      ]
    },
    "resolved_by_message_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "reference": {
      "type": "string",
      "description": "Optional pointer to where the requirement or answer is already satisfied."
    },
    "next_action_expected": {
      "$ref": "envelope.schema.json#/definitions/MessageType"
    },
    "note": {
      "type": "string",
      "minLength": 1
    }
  }
}
