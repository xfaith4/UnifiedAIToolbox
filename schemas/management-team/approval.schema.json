{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "management-team/v2/approval",
  "title": "ApprovalV2",
  "description": "Payload for message_type=Approval. Sent by Commissioner \u2192 Overseer. Grants permission to begin EXECUTION or terminates the run with hard_fail.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision",
    "commissioner_score",
    "rationale",
    "constraints_confirmed",
    "acceptance_tests_confirmed"
  ],
  "properties": {
    "decision": {
      "type": "string",
      "enum": [
        "approved",
        "hard_fail"
      ]
    },
    "commissioner_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "rationale": {
      "type": "string",
      "minLength": 30
    },
    "constraints_confirmed": {
      "type": "boolean",
      "enum": [
        true
      ]
    },
    "acceptance_tests_confirmed": {
      "type": "boolean",
      "enum": [
        true
      ]
    },
    "hard_fail_reason": {
      "type": "string",
      "minLength": 20
    },
    "approved_stack": {
      "type": "object",
      "description": "Optional narrowed or confirmed stack choices.",
      "additionalProperties": true
    },
    "approval_scope": {
      "type": "string",
      "enum": [
        "full_execution",
        "prototype_only",
        "analysis_only"
      ]
    },
    "decision_trace": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 10
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "hard_fail"
          }
        }
      },
      "then": {
        "required": [
          "hard_fail_reason"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "approved"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "commissioner_score": {
            "minimum": 80
          }
        }
      }
    }
  ]
}
