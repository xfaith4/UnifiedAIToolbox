{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "management-team/v2/goal-spec",
  "title": "GoalSpecV2",
  "description": "Payload for message_type=GoalSpec. Sent by Concierge \u2192 Commissioner. Represents a complete, auditable set of requirements with stable acceptance-test IDs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "goal_summary",
    "goal_type",
    "stack",
    "constraints",
    "interactions",
    "acceptance_tests",
    "maintenance_scope",
    "defaults_applied",
    "open_questions"
  ],
  "properties": {
    "goal_summary": {
      "type": "string",
      "minLength": 40
    },
    "goal_type": {
      "type": "string",
      "enum": [
        "app",
        "feature",
        "fix",
        "analysis",
        "migration",
        "prototype",
        "other"
      ]
    },
    "stack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime",
        "language"
      ],
      "properties": {
        "runtime": {
          "type": "string",
          "enum": [
            "node",
            "python",
            "dotnet",
            "powershell",
            "browser",
            "other"
          ]
        },
        "language": {
          "type": "string",
          "enum": [
            "javascript",
            "typescript",
            "python",
            "csharp",
            "powershell",
            "html-css-js",
            "other"
          ]
        },
        "frontend_framework": {
          "type": "string",
          "enum": [
            "react",
            "vue",
            "svelte",
            "plain_html",
            "wpf",
            "maui",
            "none",
            "other"
          ]
        },
        "bundler": {
          "type": "string",
          "enum": [
            "vite",
            "webpack",
            "parcel",
            "none",
            "other"
          ]
        },
        "state_management": {
          "type": "string",
          "enum": [
            "react_state",
            "zustand",
            "redux",
            "mobx",
            "none",
            "other"
          ]
        },
        "rendering_mode": {
          "type": "string",
          "enum": [
            "2d",
            "3d",
            "mixed",
            "n/a"
          ]
        },
        "ui_library": {
          "type": "string",
          "enum": [
            "shadcn",
            "mui",
            "tailwind_only",
            "bootstrap",
            "none",
            "other"
          ]
        },
        "test_frameworks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "other_tools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "offline_after_install",
        "no_external_apis",
        "target_devices"
      ],
      "properties": {
        "offline_after_install": {
          "type": "boolean"
        },
        "no_external_apis": {
          "type": "boolean"
        },
        "target_devices": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "typical_laptop",
              "desktop",
              "mobile",
              "tablet",
              "server",
              "unknown",
              "other"
            ]
          }
        },
        "performance_budget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fps_target": {
              "type": "number",
              "minimum": 15
            },
            "max_initial_load_ms": {
              "type": "number",
              "minimum": 0
            },
            "max_bundle_kb_gzip": {
              "type": "number",
              "minimum": 0
            },
            "geometry_budget_notes": {
              "type": "string",
              "minLength": 10
            }
          }
        },
        "security_profile": {
          "type": "string",
          "enum": [
            "low",
            "moderate",
            "high",
            "unknown"
          ]
        },
        "data_sensitivity": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "sensitive",
            "unknown"
          ]
        }
      }
    },
    "interactions": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "user_action",
          "visible_change",
          "state_change",
          "numeric_readout"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_\\-]{1,63}$"
          },
          "user_action": {
            "type": "string",
            "minLength": 10
          },
          "visible_change": {
            "type": "string",
            "minLength": 20
          },
          "state_change": {
            "type": "string",
            "minLength": 15
          },
          "numeric_readout": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "acceptance_tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "procedure",
          "expected_result",
          "evidence_required",
          "priority"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_\\-]{1,63}$"
          },
          "title": {
            "type": "string",
            "minLength": 10
          },
          "procedure": {
            "type": "string",
            "minLength": 25
          },
          "expected_result": {
            "type": "string",
            "minLength": 20
          },
          "evidence_required": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "log",
                "file_line",
                "artifact",
                "test_output",
                "stack_trace",
                "screenshot",
                "note"
              ]
            }
          },
          "priority": {
            "type": "string",
            "enum": [
              "must_pass",
              "should_pass",
              "nice_to_have"
            ]
          },
          "mapped_interaction_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_\\-]{1,63}$"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "maintenance_scope": {
      "type": "string",
      "enum": [
        "demo",
        "maintainable",
        "production_candidate"
      ]
    },
    "defaults_applied": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "maxItems": 0
    },
    "assumptions_requiring_user_confirmation": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
