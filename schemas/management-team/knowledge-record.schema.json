{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "management-team/v2/knowledge-record",
  "title": "KnowledgeRecordV2",
  "description": "Payload for message_type=KnowledgeRecord. Sent by Knowledge \u2192 Overseer after fail, blocked_requirements, or deferred verification outcomes. Designed to heal failure points, not merely describe them.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "knowledge_status",
    "classification",
    "what_broke",
    "root_cause",
    "evidence",
    "prevention_patches",
    "regression_checks"
  ],
  "properties": {
    "knowledge_status": {
      "type": "string",
      "enum": [
        "pass",
        "needs_info",
        "fail"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "requirements_incomplete",
        "dependency",
        "build",
        "test",
        "perf",
        "infra",
        "flaky",
        "policy",
        "verification_gap"
      ]
    },
    "what_broke": {
      "type": "string",
      "minLength": 10
    },
    "root_cause": {
      "type": "string",
      "minLength": 10
    },
    "repro_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "envelope.schema.json#/definitions/Evidence"
      }
    },
    "prevention_patches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "change",
          "patch_type"
        ],
        "properties": {
          "target": {
            "type": "string",
            "minLength": 1
          },
          "patch_type": {
            "type": "string",
            "enum": [
              "prompt",
              "schema",
              "policy",
              "template",
              "code",
              "test",
              "documentation"
            ]
          },
          "change": {
            "type": "string",
            "minLength": 10
          },
          "applies_to_roles": {
            "type": "array",
            "items": {
              "$ref": "envelope.schema.json#/definitions/Role"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "regression_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "anti_repeat_key": {
      "type": "string",
      "minLength": 1
    },
    "failure_fingerprint": {
      "type": "string",
      "minLength": 1
    }
  }
}
