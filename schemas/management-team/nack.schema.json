{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "management-team/v2/nack",
  "title": "NACKV2",
  "description": "Payload for message_type=NACK. Any agent may send a NACK when it receives an invalid envelope, invalid payload, invalid stage transition, or unsupported assumption.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reason",
    "missing_fields",
    "expected_schema",
    "retry_instructions",
    "rejected_message_id",
    "rejected_message_type",
    "severity"
  ],
  "properties": {
    "reason": {
      "type": "string",
      "enum": [
        "missing_required_fields",
        "invalid_enum",
        "no_evidence",
        "contradiction",
        "insufficient_items",
        "schema_version_mismatch",
        "unknown_message_type",
        "vague_acceptance_test",
        "invalid_payload_shape",
        "invalid_reference",
        "evidence_mismatch",
        "coverage_incomplete",
        "forbidden_assumption",
        "unauthorized_stage_transition",
        "role_not_allowed",
        "cross_message_inconsistency"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "error",
        "fatal"
      ]
    },
    "missing_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_schema": {
      "type": "string",
      "minLength": 1
    },
    "protocol_rule": {
      "type": "string",
      "minLength": 1
    },
    "retry_instructions": {
      "type": "string",
      "minLength": 30
    },
    "fix_examples": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "rejected_message_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "rejected_message_type": {
      "$ref": "envelope.schema.json#/definitions/MessageType"
    }
  }
}
