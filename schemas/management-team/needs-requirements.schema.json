{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "management-team/v2/needs-requirements",
  "title": "NeedsRequirementsV2",
  "description": "Payload for message_type=NeedsRequirements. Sent by Commissioner \u2192 Concierge when GoalSpec is incomplete, contradictory, or too risky to approve.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "block_reason",
    "missing",
    "proposed_acceptance_tests",
    "risk_notes",
    "commissioner_score",
    "decision"
  ],
  "properties": {
    "block_reason": {
      "type": "string",
      "enum": [
        "requirements_incomplete",
        "contradiction",
        "risk_unbounded",
        "testability_gap"
      ]
    },
    "missing": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "field",
          "question",
          "why",
          "defaults",
          "severity"
        ],
        "properties": {
          "field": {
            "type": "string",
            "minLength": 1
          },
          "question": {
            "type": "string",
            "minLength": 20
          },
          "why": {
            "type": "string",
            "minLength": 20
          },
          "defaults": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "severity": {
            "type": "string",
            "enum": [
              "blocker",
              "high",
              "medium"
            ]
          },
          "can_be_answered_from_existing_spec": {
            "type": "boolean"
          }
        }
      }
    },
    "proposed_acceptance_tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "procedure",
          "expected_result"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 10
          },
          "procedure": {
            "type": "string",
            "minLength": 20
          },
          "expected_result": {
            "type": "string",
            "minLength": 20
          }
        }
      }
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "commissioner_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "decision": {
      "type": "string",
      "enum": [
        "blocked_requirements"
      ]
    }
  }
}
