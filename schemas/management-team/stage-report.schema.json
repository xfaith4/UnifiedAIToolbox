{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "management-team/v2/stage-report",
  "title": "StageReportV2",
  "description": "Payload for message_type=StageReport. Used by Overseer and worker roles to communicate stage progress, accountability, and blocking state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stage",
    "status",
    "owner_role",
    "artifacts_expected",
    "artifacts_present",
    "errors",
    "next_expected_message_type"
  ],
  "properties": {
    "stage": {
      "$ref": "envelope.schema.json#/definitions/Stage"
    },
    "status": {
      "type": "string",
      "enum": [
        "started",
        "working",
        "completed",
        "blocked"
      ]
    },
    "owner_role": {
      "$ref": "envelope.schema.json#/definitions/Role"
    },
    "stage_attempt": {
      "type": "integer",
      "minimum": 1
    },
    "artifacts_expected": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "artifacts_present": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "artifact_manifest": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "present",
              "missing",
              "partial"
            ]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocking_message_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "depends_on_message_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
      },
      "uniqueItems": true
    },
    "next_expected_message_type": {
      "oneOf": [
        {
          "$ref": "envelope.schema.json#/definitions/MessageType"
        },
        {
          "type": "string",
          "enum": [
            "none"
          ]
        }
      ]
    },
    "percent_complete": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "decision_needed": {
      "type": "string",
      "minLength": 10
    },
    "notes": {
      "type": "string",
      "minLength": 1
    },
    "elapsed_ms": {
      "type": "number",
      "minimum": 0
    }
  }
}
