{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "management-team/v2/verification-report",
  "title": "VerificationReportV2",
  "description": "Payload for message_type=VerificationReport. Sent by Verifier \u2192 Overseer. Reports whether GoalSpec acceptance tests passed, failed, or were deferred.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verification_status",
    "checks",
    "summary"
  ],
  "properties": {
    "verification_status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked_requirements",
        "deferred"
      ]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "acceptance_test_id",
          "result",
          "evidence"
        ],
        "properties": {
          "acceptance_test_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_\\-]{1,63}$"
          },
          "result": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "defer"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "$ref": "envelope.schema.json#/definitions/Evidence"
            }
          },
          "executed_by": {
            "$ref": "envelope.schema.json#/definitions/Role"
          },
          "environment": {
            "type": "string",
            "minLength": 1
          },
          "artifact_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "result": {
                  "enum": [
                    "pass",
                    "fail"
                  ]
                }
              },
              "required": [
                "result"
              ]
            },
            "then": {
              "properties": {
                "evidence": {
                  "minItems": 1
                }
              }
            }
          }
        ]
      }
    },
    "summary": {
      "type": "string",
      "minLength": 20
    },
    "requirements_gaps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "coverage_statement": {
      "type": "string",
      "minLength": 20
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "verification_status": {
            "const": "blocked_requirements"
          }
        },
        "required": [
          "verification_status"
        ]
      },
      "then": {
        "required": [
          "requirements_gaps"
        ],
        "properties": {
          "requirements_gaps": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
